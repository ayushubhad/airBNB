<% layout("/layouts/boilerplate") %>
<body>
    <div class="row mt-3">
        <div class="col-8 offset-0">
            
    <h3>Listing Details</h3>
    </div>
    <div class="card col-6 show-card">
        <img src="<%= listing.image.url %>" class="card-img-top show-img" alt="listing_image">
  <div class="card-body">
    <p class="card-text"><b><%= listing.title%></b>
    <br>
     <%= listing.description%>
     <br>
      &#8377;<%= listing.price.toLocaleString("en-IN")%>
      <br>  
      <%= listing.location%>
      <br>
      <%= listing.country%>
    </p>

  </div>
    </div>
    
    <br/>
    <div class="btns">
<a href="/listings/<%= listing._id %>/edit" class="btn edit-btn btn-dark col-1 offset-2 ">Edit</a>
    <br></b>
    <form action="/listings/<%= listing._id %>?_method=DELETE" method="POST">
    <button type="submit" class="btn btn-dark mb-3  offset-4">Delete</button>
    </div>
    
</form>
    </div>
</body>

        
