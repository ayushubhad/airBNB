<% layout("/layouts/boilerplate") %>
<body>
    <div class="row mt-3">
        <div class="col-8 offset-0">
            
    <h3><%= listing.title%></h3>
    </div>
    <div class="card listing-card col-6 show-card">
        <img src="<%= listing.image.url %>" class="card-img-top show-img" alt="listing_image">
  <div class="card-body">
    
    
    <br>
     <%= listing.description%>
     <br>
      &#8377;<%= listing.price?.toLocaleString("en-IN")%>
      <br>  
      <%= listing.location%>
      <br>
      <%= listing.country%>
    </p>

  </div>
    </div>
    
    <br/>
    <div class="btns">
<a href="/listings/<%= listing._id %>/edit" class="btn edit-btn btn-dark col-1 offset-0">Edit</a>
    <br></b>
    <form action="/listings/<%= listing._id %>?_method=DELETE" method="POST">
    <button type="submit" class="btn btn-dark mb-3  offset-4">Delete</button>
    </div>
    <hr>
</form>
    </div>
    <div class="col-8 offset-0 mb-3">
        <h4>Leave a Review</h4>
        <form action="/listings/<%= listing.id %>/reviews" method="POST" novalidate class="needs-validation" >
            <div>
                <label for="rating" class="form-label form-range">Rating</label>
                <input type="range" min="1" max="5" id="rating" name="review[rating]">

            </div>
            <div>
                <label for="comment" class="form-label" >Comments</label>
                <textarea name="review[comment]" id="comment" cols="30" class="form-control" rows="10" required></textarea>
                <div class="valid-feedback">
                    noted!!
        </div>
        <div class="invalid-feedback">
                Please enter a valid comment!
            </div>
            </div>
            <button class="btn btn-outline-dark mt-3">Submit</button>
        </form>
        <hr>
        <p><b>All Reviews</b></p>
        <div class="row">
        <% for(review of listing.reviews) { %>
           <div class="card col-5 mb-3 ms-3">
            <div class="card-body">
                <h5 class="card-title"> Jane Doe</h5>
                <p class="card-text"><%= review.comment %></p>
                <p class="card-text"><%= review.rating %></p>
                <form  class="mb-3" method="POST" action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=delete "> 
                    <button class="btn btn-dark">Delete</button>

                </form>
            </div>
           </div>    
        <% } %>
        </div>
            
        

    </div>
</body>

        
