<% layout("/layouts/boilerplate") %>
<div class="row mt-3">
    <div class="col-8 offset-2" >
<body>
    <br><br>
    <h3>Create a new Listing</h3>
    <form action="/listings" method="POST" novalidate class="needs-validation" enctype="multipart/form-data">
       <div>
         <label for="title" class="form-label">Title</label>
        <input type="text" name="listing[title]" placeholder="enter title" class="form-control" required>
        <div class="valid-feedback">
            Title looks great!
        </div>
        <div class="invalid-feedback">
                Enter a valid title.
            </div><br>
       </div>
       <div>
        <label for="description" class="form-label">Description</label>
         <textarea type="text" name="listing[description]" placeholder="Enter Description" class="form-control" required></textarea>
         
         <div class="valid-feedback">
                Description looks good!
            </div>
            <div class="invalid-feedback">
            Enter a valid Description.
        </div><br>
       </div>
        <div>
            <label for="image" class="form-label">Upload Image</label>
            <input type="file" name="listing[image]" placeholder="Enter image URL/link" class="form-control">
            required
        </div>
        <div class="row">
            <div class="col-md-4">
            <label for="price" class="form-label">Price</label>
            <input type="number" name="listing[price]"placeholder="enter Price" class="form-control" required>
            <div class="valid-feedback">
                Price looks good!
            </div>
            <div class="invalid-feedback">
            Enter a valid price.
        </div><br>
        </div>
        <div class="col-md-8">
            <label for="country" class="form-label">Country</label>
            <input type="text" name="listing[country]" placeholder="Enter Country" class="form-control" required>
            <div class="valid-feedback">
                Country looks good!
            </div>
            <div class="invalid-feedback">
            Enter a valid country.
        </div><br>
        </div>
        </div>
        
        <div>
             <label for="location" class="form-label">Location</label>
            <input type="text" name="listing[location]" placeholder="enter location" class="form-control" required>
            <div class="valid-feedback">
                Location looks good!
            </div>
            <div class="invalid-feedback">
            Enter a valid location.
        </div><br>
        </div>
        <div>
            <div class="mb-3">
    <label for="category" class="form-label">Category</label>
    <select name="listing[category]" id="category" class="form-select" required>
        <option value="" disabled selected>Choose a category...</option>
        <option value="Trending">Trending</option>
        <option value="Rooms">Rooms</option>
        <option value="Iconic-Cities">Iconic Cities</option>
        <option value="Mountains">Mountains</option>
        <option value="Castles">Castles</option>
        <option value="Pool">Pool</option>
        <option value="Camping">Camping</option>
        <option value="Farms">Farms</option>
        <option value="Arctic">Arctic</option>
        <option value="Beach">Beach</option>
        <option value="Vineyards">Vineyards</option>
        <option value="Kitchen">Kitchen</option>
        <option value="GameHUb">GameHub</option>
        <option value="Nature">Nature</option>
        <option value="Business">Business</option>
        <option value="Vacation">Vacation</option>
        <option value="Music">Music</option>
    </select>
    <div class="invalid-feedback">Please select a category for your listing.</div>
</div>
        </div>
        <button class=" add-btn mt-3">ADD</button>
        <br><br><br>
    </form>
</body>
</div>
</div>